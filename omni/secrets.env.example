# Copy to omni/secrets.env (gitignored) and fill. Delivered to unraid-lab via Omni
# (omni/scripts/inject-secrets.sh --apply) — never committed.
HARBOR_ADMIN_PASSWORD=            # choose a strong password
GITHUB_APP_ID=                    # syscode-labs-arc-runners App id
GITHUB_APP_INSTALLATION_ID=       # its installation id
# The App private key PEM (multi-line). Easiest: point it at the downloaded file:
#   GITHUB_APP_PRIVATE_KEY="$(cat ~/syscode-labs-arc-runners.private-key.pem)"
GITHUB_APP_PRIVATE_KEY=
TS_OAUTH_CLIENT_ID=               # Tailscale OAuth client id (tag:k8s-operator)
TS_OAUTH_CLIENT_SECRET=           # Tailscale OAuth client secret
